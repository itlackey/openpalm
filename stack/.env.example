# OpenPalm Stack — Environment Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then start the core stack:
#   docker compose -f core.compose.yml up -d
#
# Or use start.sh:
#   ./start.sh

# ── Authentication ──────────────────────────────────────────────────
# Admin token for API access. Generate with: openssl rand -hex 32
OP_ADMIN_TOKEN=
# Assistant authentication token. Auto-generated if blank.
ASSISTANT_TOKEN=

# ── Service Auth ─────────────────────────────────────────────────────
MEMORY_AUTH_TOKEN=
OPENCODE_SERVER_PASSWORD=

# ── Paths ──────────────────────────────────────────────────────────
# Root of the OpenPalm data directory (defaults to ~/.openpalm)
OP_HOME=${HOME}/.openpalm
OP_UID=1000
OP_GID=1000
OP_DOCKER_SOCK=/var/run/docker.sock

# ── Images ──────────────────────────────────────────────────────────
OP_IMAGE_NAMESPACE=openpalm
OP_IMAGE_TAG=latest

# ── Ports (38XX range) ──────────────────────────────────────────────
OP_ASSISTANT_PORT=3800
OP_ADMIN_PORT=3880
OP_ADMIN_OPENCODE_PORT=3881
OP_SCHEDULER_PORT=3897
OP_MEMORY_PORT=3898
OP_GUARDIAN_PORT=3899
OP_INGRESS_PORT=3080

# ── Networking ──────────────────────────────────────────────────────
# SECURITY: Bind addresses default to 127.0.0.1 (localhost only).
# Changing to 0.0.0.0 exposes services to the network.
OP_INGRESS_BIND_ADDRESS=127.0.0.1

# ── LLM Provider Keys ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=

# ── Embedding ──────────────────────────────────────────────────────
EMBEDDING_MODEL=
EMBEDDING_DIMS=

# ── Memory ──────────────────────────────────────────────────────────
MEMORY_USER_ID=default_user

# ── Owner ──────────────────────────────────────────────────────────
OWNER_NAME=
OWNER_EMAIL=

# ── Channel HMAC Secrets ────────────────────────────────────────────
# Per-channel secrets (auto-generated by tooling if blank)
# CHANNEL_CHAT_SECRET=
# CHANNEL_DISCORD_SECRET=
# CHANNEL_SLACK_SECRET=
