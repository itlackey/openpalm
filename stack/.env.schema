# OpenPalm stack-level environment schema
# Combines core system and user variables.
# See core/system.env.schema and core/user.env.schema for details.
#
# @required — variable must be set for the stack to start
# @sensitive — value contains secrets, redact from logs
#
# Authentication
# @required @sensitive
OP_ADMIN_TOKEN=
# @sensitive
ASSISTANT_TOKEN=

# Service Auth
# @sensitive
MEMORY_AUTH_TOKEN=
# @sensitive
OPENCODE_SERVER_PASSWORD=

# Paths
# @required
OP_HOME=
OP_UID=1000
OP_GID=1000
OP_DOCKER_SOCK=/var/run/docker.sock

# Images
OP_IMAGE_NAMESPACE=openpalm
OP_IMAGE_TAG=latest

# Ports
OP_ASSISTANT_PORT=3800
OP_ADMIN_PORT=3880
OP_ADMIN_OPENCODE_PORT=3881
OP_SCHEDULER_PORT=3897
OP_MEMORY_PORT=3898
OP_GUARDIAN_PORT=3899
OP_INGRESS_PORT=3080

# Networking
OP_INGRESS_BIND_ADDRESS=127.0.0.1

# LLM Provider Keys
# @sensitive
OPENAI_API_KEY=
OPENAI_BASE_URL=
# @sensitive
ANTHROPIC_API_KEY=
# @sensitive
GROQ_API_KEY=
# @sensitive
MISTRAL_API_KEY=
# @sensitive
GOOGLE_API_KEY=
# @sensitive
MCP_API_KEY=
# @sensitive
EMBEDDING_API_KEY=

# System LLM
SYSTEM_LLM_PROVIDER=
SYSTEM_LLM_BASE_URL=
SYSTEM_LLM_MODEL=

# Embedding
EMBEDDING_MODEL=
EMBEDDING_DIMS=

# Memory
MEMORY_USER_ID=default_user

# Owner
OWNER_NAME=
OWNER_EMAIL=

# Setup Status
OP_SETUP_COMPLETE=false
