# OpenPalm — User Configuration
#
# Copy to ~/.openpalm/vault/user/user.env
# Edit these values directly. The assistant picks up changes within
# seconds via file watcher — no restart needed.

# ── LLM Provider Keys ──────────────────────────────────────────────
# Set the API key for your preferred provider. At least one is required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=
MCP_API_KEY=
EMBEDDING_API_KEY=

# Custom OpenAI-compatible endpoint (e.g., for local models via Ollama)
OPENAI_BASE_URL=

# ── System LLM ──────────────────────────────────────────────────────
# Override the LLM used for system tasks (automations, memory extraction).
# Leave blank to use the default provider.
SYSTEM_LLM_PROVIDER=
SYSTEM_LLM_BASE_URL=
SYSTEM_LLM_MODEL=

# ── Embedding ──────────────────────────────────────────────────────
EMBEDDING_MODEL=
EMBEDDING_DIMS=

# ── Memory ──────────────────────────────────────────────────────────
MEMORY_USER_ID=default_user

# ── Owner ──────────────────────────────────────────────────────────
OWNER_NAME=
OWNER_EMAIL=
