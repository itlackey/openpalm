# OpenPalm — System-Managed Stack Environment
#
# Copy to ~/.openpalm/vault/stack/stack.env
# These values are normally managed by the CLI or admin. Edit only if
# you are running a manual (no-CLI) installation.

# ── Authentication ──────────────────────────────────────────────────
# Admin token for API access. Generate with: openssl rand -hex 32
OP_ADMIN_TOKEN=
# Assistant authentication token. Generate with: openssl rand -hex 32
ASSISTANT_TOKEN=

# ── Service Auth ─────────────────────────────────────────────────────
# Internal service tokens. Generate with: openssl rand -hex 32
MEMORY_AUTH_TOKEN=
OPENCODE_SERVER_PASSWORD=

# ── Paths ──────────────────────────────────────────────────────────
OP_HOME=${HOME}/.openpalm
OP_UID=1000
OP_GID=1000
OP_DOCKER_SOCK=/var/run/docker.sock

# ── Images ──────────────────────────────────────────────────────────
OP_IMAGE_NAMESPACE=openpalm
OP_IMAGE_TAG=latest

# ── Ports (38XX range) ──────────────────────────────────────────────
OP_ASSISTANT_PORT=3800
OP_ADMIN_PORT=3880
OP_ADMIN_OPENCODE_PORT=3881
OP_SCHEDULER_PORT=3897
OP_MEMORY_PORT=3898
OP_GUARDIAN_PORT=3899
OP_INGRESS_PORT=3080

# ── Networking ──────────────────────────────────────────────────────
# SECURITY: Bind addresses default to 127.0.0.1 (localhost only).
# Changing to 0.0.0.0 exposes services to the network.
OP_INGRESS_BIND_ADDRESS=127.0.0.1

# ── Setup Status ────────────────────────────────────────────────────
OP_SETUP_COMPLETE=false

# ── Channel HMAC Secrets ────────────────────────────────────────────
# Per-channel secrets are appended here when channels are installed.
# Generate with: openssl rand -hex 16
# CHANNEL_CHAT_SECRET=
# CHANNEL_DISCORD_SECRET=
# CHANNEL_SLACK_SECRET=
