# setup.env — Configuration for OpenPalm Azure VM deployment.
#
# Copy this file to setup.env and fill in your values:
#   cp setup.env.example setup.env
#
# Environment variables set before running deploy.sh take precedence
# over values in this file.

# ── Required ──────────────────────────────────────────────────────────

AZURE_SUBSCRIPTION_ID=your-subscription-id
SETUP_SPEC_FILE=./my-setup.yaml

# ── Optional (defaults shown) ────────────────────────────────────────

# LOCATION=eastus
# RESOURCE_GROUP=rg-openpalm-vm
# ADMIN_USERNAME=openpalm
# OPENPALM_VERSION=v0.10.0
# STORAGE_NAME=stopenpalm
# BACKUP_SHARE=openpalm-backups
# KV_NAME=kv-openpalm
