# deploy.env — All config for OpenPalm Azure VM deployment.
#
# Copy to deploy.env, fill in your values, then run ./deploy.sh
# This file is sourced by bash. Quote values with special characters.

# ── Required ──────────────────────────────────────────────────────────

AZURE_SUBSCRIPTION_ID=your-subscription-id
SETUP_SPEC_FILE=./deploy.spec.yaml

# ── Optional (defaults shown) ────────────────────────────────────────

# LOCATION=eastus2
# RESOURCE_GROUP=rg-openpalm-vm
# ADMIN_USERNAME=openpalm
# OPENPALM_VERSION=v0.10.2
# STORAGE_NAME=stopenpalm
# BACKUP_SHARE=openpalm-backups
# DATA_SHARE=openpalm
# KV_NAME=kv-openpalm

# ── Azure AI Foundry ─────────────────────────────────────────────────
# These are used by the memory service (OP_CAP_* variables) and by the
# assistant's Azure proxy (azure-proxy.ts). The resource name must match
# an AI Foundry resource with model deployments.

AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_RESOURCE_NAME=your-ai-foundry-resource-name

# ── Secrets (stored in Key Vault, fetched by VM at boot) ─────────────

OP_ADMIN_TOKEN=change-me-to-a-long-random-secret

# Other LLM provider keys (uncomment if your spec uses them):
# OPENAI_API_KEY=sk-your-api-key
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
# TOGETHER_API_KEY=...
# XAI_API_KEY=...

# Channel credentials:
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# DISCORD_BOT_TOKEN=...
