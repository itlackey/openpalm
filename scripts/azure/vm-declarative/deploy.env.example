# deploy.env — All config for OpenPalm Azure VM deployment.
#
# Copy to deploy.env, fill in your values, then run ./deploy.sh
# This file is sourced by bash. Quote values with special characters.

# ── Required ──────────────────────────────────────────────────────────

AZURE_SUBSCRIPTION_ID=your-subscription-id
SETUP_SPEC_FILE=./deploy.spec.yaml

# ── Optional (defaults shown) ────────────────────────────────────────

# LOCATION=eastus
# RESOURCE_GROUP=rg-openpalm-vm
# ADMIN_USERNAME=openpalm
# OPENPALM_VERSION=v0.10.0
# STORAGE_NAME=stopenpalm
# BACKUP_SHARE=openpalm-backups
# KV_NAME=kv-openpalm

# ── Secrets (stored in Key Vault, fetched by VM at boot) ─────────────

OP_ADMIN_TOKEN=change-me-to-a-long-random-secret
OPENAI_API_KEY=sk-your-api-key

# Other providers (uncomment the ones your spec uses):
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
# TOGETHER_API_KEY=...
# XAI_API_KEY=...

# ── Azure AI Foundry (optional) ──────────────────────────────────────
# Set ENABLE_FOUNDRY=true to deploy an Azure AI Services account with
# GPT-5.2, GPT-5.4-mini, and text-embedding-3-large model deployments.
# The stack's memory/embedding capabilities and an OpenCode provider
# will be auto-configured to use the Foundry endpoint.

# ENABLE_FOUNDRY=true
# FOUNDRY_NAME=ai-openpalm          # must be globally unique

# Override model defaults (deployment-name / model-name / version):
# FOUNDRY_LLM_DEPLOYMENT=gpt-52
# FOUNDRY_LLM_MODEL=gpt-5.2
# FOUNDRY_LLM_VERSION=2026-01-01
# FOUNDRY_SLM_DEPLOYMENT=gpt-54-mini
# FOUNDRY_SLM_MODEL=gpt-5.4-mini
# FOUNDRY_SLM_VERSION=2026-01-01
# FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# FOUNDRY_EMBEDDING_DIMS=3072

# ── Caddy reverse proxy (HTTPS via Let's Encrypt) ───────────────────
# Set one or more FQDNs to enable Caddy. Each FQDN maps to a service.
# DNS A records for each FQDN must point at the VM public IP.

# CADDY_GUARDIAN_FQDN=guardian.example.com
# CADDY_ADMIN_FQDN=admin.example.com
# CADDY_ASSISTANT_FQDN=assistant.example.com
# CADDY_EMAIL=you@example.com

# Channel credentials:
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# DISCORD_BOT_TOKEN=...

