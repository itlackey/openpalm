# secrets.env — Secret values referenced as ${VAR} in the setup spec.
#
# Env var names match PROVIDER_KEY_MAP / CHANNEL_CREDENTIAL_ENV_MAP.
# This file is stored in Key Vault and fetched by the VM at boot.
# Quote values with special characters: API_KEY='sk-abc!@#'

OP_ADMIN_TOKEN=change-me-to-a-long-random-secret
OPENAI_API_KEY=sk-your-api-key

# Other providers (uncomment the ones your spec uses):
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# GOOGLE_API_KEY=...
# DEEPSEEK_API_KEY=...
# TOGETHER_API_KEY=...
# XAI_API_KEY=...

# Channel credentials:
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
# DISCORD_BOT_TOKEN=...
