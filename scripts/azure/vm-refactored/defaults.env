# defaults.env — All configurable values in one place.
#
# The deploy script sources this file, then environment variables override
# any value set here.  This is the single reference for every tunable.
#
# Required (no defaults — must be set in the environment):
#   AZURE_SUBSCRIPTION_ID
#   SETUP_SPEC_FILE         path to a local OpenPalm setup YAML/JSON

# ── Azure resource names ─────────────────────────────────────────────────
LOCATION=eastus
RESOURCE_GROUP=rg-openpalm-vm
VM_NAME=openpalm-vm
KV_NAME=kv-openpalm-vm
STORAGE_NAME=stopenpalm
BACKUP_SHARE=openpalm-backups

# ── VM settings ──────────────────────────────────────────────────────────
ADMIN_USERNAME=openpalm
VM_SIZE=Standard_B1ms
OS_DISK_SIZE=64
IMAGE_URN=Canonical:ubuntu-24_04-lts:server:latest
TAGS="app=openpalm env=dev managed-by=azure-cli"

# ── Networking ───────────────────────────────────────────────────────────
VNET_NAME=vnet-openpalm
VNET_PREFIX=10.0.0.0/16
SUBNET_NAME=snet-openpalm-vm
SUBNET_PREFIX=10.0.1.0/24
NSG_NAME=nsg-openpalm-vm

# ── OpenPalm ─────────────────────────────────────────────────────────────
OPENPALM_VERSION=v0.10.0
# Derived at runtime — do not set manually:
#   OPENPALM_INSTALL_DIR=/home/<ADMIN_USERNAME>/.local/bin
#   OPENPALM_HOME=/home/<ADMIN_USERNAME>/.openpalm

# ── Slack (optional — omit both to deploy without Slack) ─────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
