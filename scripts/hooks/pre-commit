#!/usr/bin/env bash
# OpenPalm pre-commit hook — prevents committing leaked secrets.
# Install via: ./scripts/install-hooks.sh
#
# Strategy:
#   1. If varlock is available and vault/user.env exists, use varlock scan.
#      This resolves actual @sensitive values and searches for them —
#      catches ANY secret format, not just known prefixes.
#   2. Fall back to grep pattern matching for provider-specific key formats
#      when varlock is not installed or no vault/user.env exists.

set -e

# ── Try varlock scan first ──────────────────────────────────────────
VARLOCK_BIN=""
OP_HOME_RESOLVED="${OP_HOME:-${HOME}/.openpalm}"
STATE_HOME="${OP_STATE_HOME:-${OP_HOME_RESOLVED}}"
VAULT_HOME="${OP_HOME_RESOLVED}/vault"
SECRETS_ENV="${VAULT_HOME}/user.env"
SCHEMA="${VAULT_HOME}/user.env.schema"

# Check common locations for the varlock binary
for candidate in \
    "${STATE_HOME}/bin/varlock" \
    "${HOME}/.varlock/bin/varlock" \
    "$(command -v varlock 2>/dev/null || true)"; do
  if [ -x "$candidate" ]; then
    VARLOCK_BIN="$candidate"
    break
  fi
done

if [ -n "$VARLOCK_BIN" ] && [ -f "$SECRETS_ENV" ]; then
  # varlock scan resolves @sensitive values from .env files and searches
  # the working tree for plaintext occurrences. If it finds your actual
  # OPENAI_API_KEY value in a committed file, it catches it — regardless
  # of whether the key matches a known prefix pattern.
  #
  # varlock expects --path <dir>/ with .env + .env.schema inside.
  # Stage user.env as .env in a temp dir to match the convention used
  # by the CLI and admin validation.
  TMP_ENV_DIR="$(mktemp -d 2>/dev/null || true)"
  if [ -n "$TMP_ENV_DIR" ] && [ -d "$TMP_ENV_DIR" ]; then
    cp "$SECRETS_ENV" "$TMP_ENV_DIR/.env" 2>/dev/null || true
    if [ -f "$SCHEMA" ]; then
      cp "$SCHEMA" "$TMP_ENV_DIR/.env.schema" 2>/dev/null || true
    fi
    exec "$VARLOCK_BIN" scan --path "$TMP_ENV_DIR/"
    # exec replaces this process — if we get here, varlock scan ran.
  fi
fi

# ── Fallback: grep for known key prefixes ───────────────────────────
# When varlock is not available (new contributor, CI-like environment),
# do a best-effort pattern match on staged additions.
PATTERN='(sk-[A-Za-z0-9]{20,}|gsk_[A-Za-z0-9]{30,}|AIza[A-Za-z0-9_-]{35}|(^|[^0-9a-f])[0-9a-f]{64}([^0-9a-f]|$))'

STAGED=$(git diff --staged --unified=0 | grep '^+' | grep -v '^+++' | grep -viE 'sha256|sha_256|checksum|digest|\.tar\.gz|VARLOCK_CHECKSUMS' || true)

if [ -z "$STAGED" ]; then
  exit 0
fi

if echo "$STAGED" | grep -qE "$PATTERN" 2>/dev/null; then
  echo "pre-commit: potential API key detected in staged changes." >&2
  echo "    openpalm install  # sets up varlock and required secrets files" >&2
  echo "  Or install varlock via the upstream script: https://github.com/dmno-dev/varlock" >&2
  echo "  To bypass this hook (not recommended): git commit --no-verify" >&2
  echo "" >&2
  git diff --staged --unified=0 | grep -E "$PATTERN" >&2 || true
  exit 1
fi
