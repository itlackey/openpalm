{
  "discord": {
    "package": "@openpalm/channel-discord",
    "version": "latest",
    "port": 8184,
    "networks": ["channel_lan"],
    "envVars": ["CHANNEL_DISCORD_SECRET"],
    "description": "Discord webhook adapter"
  },
  "chat": {
    "package": "@openpalm/channel-chat",
    "version": "latest",
    "port": 8181,
    "networks": ["channel_lan"],
    "envVars": ["CHANNEL_CHAT_SECRET", "OPENAI_COMPAT_API_KEY"],
    "caddy": "handle_path /channels/chat/* {\n\timport lan_only\n\treverse_proxy channel-chat:8181\n}\n",
    "description": "OpenAI/Anthropic-compatible chat API"
  },
  "api": {
    "package": "@openpalm/channel-api",
    "version": "latest",
    "port": 8186,
    "networks": ["channel_lan"],
    "envVars": ["CHANNEL_API_SECRET", "OPENAI_COMPAT_API_KEY"],
    "description": "OpenAI chat completions endpoint"
  }
}
