# OpenPalm — User Secrets
#
# Schema: see secrets.env.schema for variable types and validation rules.
#
# Place this file at vault/user.env (default: ~/.openpalm/vault/user.env).
# This file uses `export` so it can be sourced in a shell and is also compatible
# with Docker Compose v2 env_file.
#
# Only user-provided secrets belong here. All infrastructure configuration
# (paths, UID/GID, networking, image tags, memory URLs) is auto-detected
# by the admin and written to vault/system.env. You never need
# to set those values manually.

# ── Required ─────────────────────────────────────────────────────────
# Admin API authentication token — change this before exposing the stack
export OP_ADMIN_TOKEN=
# Legacy alias — only needed if your compose file still references ADMIN_TOKEN:
# export ADMIN_TOKEN=

# ── LLM Provider Keys (at least one recommended) ────────────────────
# Required for the memory service; optional for the assistant
export OPENAI_API_KEY=
export OPENAI_BASE_URL=
# export ANTHROPIC_API_KEY=
# export GROQ_API_KEY=
# export MISTRAL_API_KEY=
# export GOOGLE_API_KEY=

# ── Memory ────────────────────────────────────────────────────────────
export MEMORY_USER_ID=default_user

# ── Optional: custom home directory ─────────────────────────────────
# Uncomment and set if you want a custom install path.
# Docker compose inherits this from the shell env automatically.
# export OP_HOME=/custom/path
