{
  "name": "openpalm",
  "version": "0.9.0-rc12",
  "private": true,
  "license": "MPL-2.0",
  "workspaces": [
    "packages/admin",
    "core/guardian",
    "packages/cli",
    "core/memory",
    "packages/channels-sdk",
    "packages/channel-discord",
    "packages/channel-api",
    "packages/channel-chat",
    "packages/assistant-tools",
    "packages/memory"
  ],
  "scripts": {
    "admin:dev": "bun run --cwd packages/admin dev",
    "admin:build": "bun run --cwd packages/admin build",
    "admin:check": "bun run --cwd packages/admin check",
    "admin:test": "cd packages/admin && npm test",
    "admin:test:unit": "cd packages/admin && npm run test:unit -- --run",
    "admin:test:e2e": "cd packages/admin && export $(grep -E '^(OPENCODE_SERVER_PASSWORD|MEMORY_AUTH_TOKEN)=' ../../.dev/state/artifacts/secrets.env | xargs) 2>/dev/null; RUN_DOCKER_STACK_TESTS=1 RUN_LLM_TESTS=1 ADMIN_TOKEN=dev-admin-token npm run test:e2e",
    "admin:test:e2e:mocked": "cd packages/admin && npm run test:e2e:mocked",
    "admin:test:stack": "cd packages/admin && RUN_DOCKER_STACK_TESTS=1 npm run test:e2e",
    "admin:test:llm": "cd packages/admin && RUN_DOCKER_STACK_TESTS=1 RUN_LLM_TESTS=1 npm run test:e2e",
    "guardian:dev": "bun run core/guardian/src/server.ts",
    "guardian:test": "bun test --cwd core/guardian",
    "sdk:test": "bun test --cwd packages/channels-sdk",
    "channel:chat:dev": "bun run packages/channel-chat/src/index.ts",
    "channel:api:dev": "bun run packages/channel-api/src/index.ts",
    "channel:discord:dev": "bun run packages/channel-discord/src/index.ts",
    "cli:test": "bun test --cwd packages/cli",
    "cli:build:linux-x64": "bun run --cwd packages/cli build:linux-x64",
    "cli:build:linux-arm64": "bun run --cwd packages/cli build:linux-arm64",
    "cli:build:darwin-x64": "bun run --cwd packages/cli build:darwin-x64",
    "cli:build:darwin-arm64": "bun run --cwd packages/cli build:darwin-arm64",
    "cli:build:windows-x64": "bun run --cwd packages/cli build:windows-x64",
    "cli:build:windows-arm64": "bun run --cwd packages/cli build:windows-arm64",
    "dev:setup": "./scripts/dev-setup.sh --seed-env",
    "dev:stack": "docker compose -f .dev/state/artifacts/docker-compose.yml --env-file .dev/state/artifacts/stack.env --env-file .dev/state/artifacts/secrets.env up -d",
    "dev:build": "docker compose --project-directory . -f assets/docker-compose.yml -f compose.dev.yaml --env-file .dev/state/artifacts/stack.env --env-file .dev/state/artifacts/secrets.env up --build -d",
    "test": "bun test packages/channels-sdk packages/channel-chat packages/channel-api packages/channel-discord packages/cli core/guardian/",
    "test:parity": "bun test packages/memory/parity-tests/",
    "test:benchmark": "./packages/memory/benchmark-tests/run-benchmarks.sh",
    "test:benchmark:perf": "./packages/memory/benchmark-tests/run-benchmarks.sh perf",
    "test:benchmark:quality": "./packages/memory/benchmark-tests/run-benchmarks.sh quality",
    "test:benchmark:ts-only": "./packages/memory/benchmark-tests/run-benchmarks.sh --no-python",
    "check": "bun run admin:check && bun run sdk:test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18"
  }
}
