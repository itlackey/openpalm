{
  "mem0": {
    "llm": {
      "provider": "openai",
      "config": {
        "model": "gpt-4o",
        "temperature": 0.1,
        "max_tokens": 2000,
        "api_key": "env:OPENAI_API_KEY",
        "openai_base_url": "https://api.openai.com/v1"
      }
    },
    "embedder": {
      "provider": "openai",
      "config": {
        "model": "text-embedding-3-small",
        "api_key": "env:OPENAI_API_KEY",
        "openai_base_url": "https://api.openai.com/v1"
      }
    },
    "vector_store": {
      "provider": "sqlite-vec",
      "config": {
        "collection_name": "memory",
        "db_path": "/data/memory.db",
        "embedding_model_dims": 1536
      }
    }
  },
  "memory": {
    "custom_instructions": ""
  }
}
