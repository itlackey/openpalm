# OpenViking knowledge engine configuration
# ---

# Root API key for Viking access.
# Auto-generated during instance creation if left blank.
# @required @sensitive
OPENVIKING_API_KEY=

# ---

# Embedding settings come from the stack capability env vars
# (`OP_CAP_EMBEDDINGS_*`) rather than addon-specific fields.

# Image version
# ---

# OpenViking image tag for upgrades.
OPENVIKING_IMAGE_TAG=v0.2.12
