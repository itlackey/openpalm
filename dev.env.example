# OpenPalm Stack — Dev Environment Configuration
#
# Copy this file to .env and adjust paths as needed.
# Secrets (ADMIN_TOKEN, LLM keys) belong in CONFIG_HOME/secrets.env,
# NOT here. Run: scripts/dev-setup.sh --seed-env to create it.

# ── Secrets ──────────────────────────────────────────────────────────
# ADMIN_TOKEN and LLM keys live in CONFIG_HOME/secrets.env (seeded by
# dev-setup.sh --seed-env). They are staged to STATE_HOME/artifacts/
# and passed to docker compose via --env-file. Do NOT duplicate them
# here — Vite loads this file into process.env, which takes precedence
# over --env-file and would shadow the real values with empty strings.

# ── Paths (XDG-compliant) ──────────────────────────────────────────
# All user-editable configuration lives under CONFIG_HOME.
OPENPALM_DATA_HOME=../.dev/data          # Persistent data (postgres, qdrant, etc.)
OPENPALM_STATE_HOME=../.dev/state        # State directory (artifacts, configs)
OPENPALM_CONFIG_HOME=../.dev/config      # Config directory (channels, opencode)
OPENPALM_WORK_DIR=../.dev/openpalm               # Assistant working directory

# ── Images ───────────────────────────────────────────────────────────
# OPENPALM_IMAGE_NAMESPACE=openpalm
# OPENPALM_IMAGE_TAG=latest

# ── Networking ───────────────────────────────────────────────────────
# OPENPALM_INGRESS_BIND_ADDRESS=127.0.0.1
# OPENPALM_INGRESS_PORT=8080
# OPENPALM_ACCESS_SCOPE=lan

# ── User/Group (for bind mount permissions) ──────────────────────────
# OPENPALM_UID=1000
# OPENPALM_GID=1000

# ── Docker Socket ────────────────────────────────────────────────────
# Auto-detected from `docker context inspect` by setup scripts.
# Override if needed (e.g. OrbStack, Colima, Rancher Desktop).
# OPENPALM_DOCKER_SOCK=/var/run/docker.sock

# ── OpenMemory ───────────────────────────────────────────────────────
# OPENMEMORY_DASHBOARD_API_URL=http://localhost:8765
# OPENMEMORY_USER_ID=default_user
