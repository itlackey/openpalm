{
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "@openpalm/assistant-tools@latest",
    "akm-opencode@latest",
    "opencode-varlock@latest"
    // "openviking-opencode"
  ],

  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": false
  },

  "permission": {
    "read": {
      "/home/opencode/.local/share/opencode/auth.json": "deny",
      "/home/opencode/.local/share/opencode/mcp-auth.json": "deny"
    },

    "external_directory": {
      "/tmp": "allow",
      "/home/opencode": "allow"
    }
  }
}
