# OpenPalm Stack — Dev Environment Configuration
#
# Copy this file to .env and adjust paths as needed.
# Secrets belong in .dev/vault/... or ~/.openpalm/vault/... depending on the
# environment you are running. Do not put real secrets in this file.

# ── Secrets ──────────────────────────────────────────────────────────
# Runtime secrets are loaded from the vault env files. Do NOT duplicate them
# here or this dev .env may shadow the real values.

# ── Paths (relative to repo root) ────────────────────────────────
# All directories (config/, stack/, vault/, data/, logs/) live under OP_HOME.
OP_HOME=.dev                    # Dev home directory (default runtime: ~/.openpalm)
# OP_WORK_DIR is compatibility-only and not used by the shipped compose files.
OP_WORK_DIR=.dev/openpalm

# ── Images ───────────────────────────────────────────────────────────
# OP_IMAGE_NAMESPACE=openpalm
# OP_IMAGE_TAG=v0.8.0

# ── Core binds ───────────────────────────────────────────────────────
# OP_ADMIN_BIND_ADDRESS=127.0.0.1
# OP_ADMIN_PORT=3880
# OP_ASSISTANT_BIND_ADDRESS=127.0.0.1
# OP_ASSISTANT_PORT=3800
# OP_ASSISTANT_SSH_BIND_ADDRESS=127.0.0.1
# OP_ASSISTANT_SSH_PORT=2222
# OP_MEMORY_BIND_ADDRESS=127.0.0.1
# OP_MEMORY_PORT=3898
# OP_CHAT_BIND_ADDRESS=127.0.0.1
# OP_CHAT_PORT=3820
# OP_API_BIND_ADDRESS=127.0.0.1
# OP_API_PORT=3821
# OP_VOICE_BIND_ADDRESS=127.0.0.1
# OP_VOICE_PORT=3810

# ── User/Group (for bind mount permissions) ──────────────────────────
# OP_UID=1000
# OP_GID=1000

# ── Docker Socket ────────────────────────────────────────────────────
# Auto-detected from `docker context inspect` by setup scripts.
# Override if needed (e.g. OrbStack, Colima, Rancher Desktop).
# OP_DOCKER_SOCK=/var/run/docker.sock

# ── Memory ────────────────────────────────────────────────────────────
# MEMORY_USER_ID=default_user
