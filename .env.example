# OpenPalm Stack — Dev Environment Configuration
#
# Copy this file to .env and adjust paths as needed.
# Secrets (OP_ADMIN_TOKEN, LLM keys) belong in vault/user.env,
# NOT here. Run: scripts/dev-setup.sh --seed-env to create it.

# ── Secrets ──────────────────────────────────────────────────────────
# OP_ADMIN_TOKEN and LLM keys live in vault/user.env (seeded by
# dev-setup.sh --seed-env). They are staged to vault/system.env
# and passed to docker compose via --env-file. Do NOT duplicate them
# here — Vite loads this file into process.env, which takes precedence
# over --env-file and would shadow the real values with empty strings.

# ── Paths (relative to repo root) ────────────────────────────────
# All directories (config/, vault/, data/, logs/) live under OP_HOME.
OP_HOME=.dev                    # Dev home directory (default: ~/.openpalm)
OP_WORK_DIR=.dev/openpalm      # Assistant working directory

# ── Images ───────────────────────────────────────────────────────────
# OP_IMAGE_NAMESPACE=openpalm
# OP_IMAGE_TAG=v0.8.0

# ── Networking ───────────────────────────────────────────────────────
# OP_INGRESS_BIND_ADDRESS=127.0.0.1
# OP_INGRESS_PORT=8080
# OP_ACCESS_SCOPE=lan

# ── User/Group (for bind mount permissions) ──────────────────────────
# OP_UID=1000
# OP_GID=1000

# ── Docker Socket ────────────────────────────────────────────────────
# Auto-detected from `docker context inspect` by setup scripts.
# Override if needed (e.g. OrbStack, Colima, Rancher Desktop).
# OP_DOCKER_SOCK=/var/run/docker.sock

# ── Memory ────────────────────────────────────────────────────────────
# MEMORY_USER_ID=default_user
